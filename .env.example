# Copie este arquivo para ".env" (local) e preencha com os dados do seu projeto Supabase.
# No painel do Supabase: Project Settings > API

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ---------------------------------------------------------------------------
# As variáveis abaixo NÃO levam prefixo VITE_ porque são usadas só no servidor
# (função serverless em /api), nunca ficam expostas no navegador.
# Configure-as direto no painel da Vercel: Project Settings > Environment Variables
# ---------------------------------------------------------------------------

# Chave da API da Groq (https://console.groq.com/keys), usada para gerar
# as perguntas do teste de QI.
GROQ_API_KEY=

# Opcional: modelo da Groq a usar (padrão: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
